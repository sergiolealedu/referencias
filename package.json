{
  "name": "referencias-app",
  "version": "1.1.24",
  "private": true,
  "description": "Gerenciamento bibliográfico para doutorado — monorepo full-stack",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergiolealedu/referencias.git"
  },
  "bugs": {
    "url": "https://github.com/sergiolealedu/referencias/issues"
  },
  "homepage": "https://github.com/sergiolealedu/referencias#readme",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "npm run start -w backend",
    "build:android": "npm run build:android -w frontend",
    "android:assemble": "node scripts/android-gradle.mjs assembleRelease",
    "android:assemble:debug": "node scripts/android-gradle.mjs assembleDebug",
    "android:bundle": "node scripts/android-gradle.mjs bundleRelease",
    "android:release": "npm run build:android && npm run android:bundle && npm run android:assemble",
    "build:android:copy": "node scripts/run-build-android-copy.mjs",
    "commit:push": "powershell -ExecutionPolicy Bypass -File ./commit-push.ps1",
    "publish:server": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy/publish-to-server.ps1 -SkipConfirm",
    "release:server": "powershell -ExecutionPolicy Bypass -File ./release.ps1",
    "backup:server": "powershell -ExecutionPolicy Bypass -File ./scripts/backup/server-data.ps1 -Action Backup -SkipConfirm",
    "restore:server": "powershell -ExecutionPolicy Bypass -File ./scripts/backup/server-data.ps1 -Action Restore -Latest -SkipConfirm",
    "backup:server:list": "powershell -ExecutionPolicy Bypass -File ./scripts/backup/server-data.ps1 -Action List",
    "install:server": "powershell -ExecutionPolicy Bypass -File ./install-server.ps1 -SkipConfirm"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
