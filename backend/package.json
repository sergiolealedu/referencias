{
  "name": "@sergiolealedu/referencias-backend",
  "version": "1.1.24",
  "description": "API Express + SQLite do sistema Referências",
  "type": "module",
  "main": "dist/server.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergiolealedu/referencias.git",
    "directory": "backend"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node -e \"const fs=require('node:fs');fs.copyFileSync('src/store/schema.sql','dist/store/schema.sql');fs.mkdirSync('dist/registry',{recursive:true});fs.copyFileSync('src/registry/schema.sql','dist/registry/schema.sql');\"",
    "start": "node dist/server.js",
    "migrate:json": "tsx scripts/migrate-json-to-sqlite.ts",
    "detect:duplicates": "tsx scripts/detect-duplicates.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
