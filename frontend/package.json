{
  "name": "@sergiolealedu/referencias-frontend",
  "version": "1.0.0",
  "description": "SPA React/Vite do sistema Referências (build estático)",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergiolealedu/referencias.git",
    "directory": "frontend"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:sync:only": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "build:android": "npm run cap:sync",
    "android:assemble": "node ../scripts/android-gradle.mjs assembleRelease",
    "android:bundle": "node ../scripts/android-gradle.mjs bundleRelease",
    "android:release": "npm run cap:sync && npm run android:bundle && npm run android:assemble"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^7.0.1",
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.4.2",
    "@capacitor/filesystem": "^7.1.2",
    "@capacitor/network": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@tanstack/react-query": "^5.101.2",
    "jeep-sqlite": "^2.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
